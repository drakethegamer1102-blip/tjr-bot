# Copy this file to ".env" and fill in your real values. NEVER commit .env or share it.

# --- Alpaca PAPER trading keys ---
# Get them at https://alpaca.markets -> switch to "Paper" -> API Keys -> Generate
ALPACA_API_KEY_ID=your_key_id_here
ALPACA_API_SECRET=your_secret_here
# Keep this "true" so we trade fake money on the paper endpoint.
ALPACA_PAPER=true

# --- Telegram bot (phone alerts) ---
# Create a bot via @BotFather (gives the token); get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=123456:your_bot_token_here
TELEGRAM_CHAT_ID=your_numeric_chat_id_here
